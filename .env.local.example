# ---------------------------------------------------------------------------
# Parrotkit dedicated Supabase project
# 1) Create a NEW Supabase project for Parrotkit
# 2) Use that project's values only (do not reuse keys from other services)
# ---------------------------------------------------------------------------

# Optional: keep ref here for your own safety checks/scripts.
SUPABASE_PROJECT_REF="your-parrotkit-project-ref"

# Supabase API
NEXT_PUBLIC_SUPABASE_URL="https://your-parrotkit-project-ref.supabase.co"
# Use the modern publishable/secret key pair for new projects.
# It rotates independently from the project's JWT signing secret, so key rotation is safer than legacy anon/service_role JWT keys.
# If the Supabase dashboard shows NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY, copy that same value here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-parrotkit-publishable-key"
# Secret keys stay server-only because they are privileged credentials for admin flows and data maintenance.
SUPABASE_SECRET_KEY="your-parrotkit-secret-key"

# Database URL used by server-side DB tools (schema snapshot, drizzle generation, etc.)
# Use the pooled Postgres URL for Next.js/serverless workloads so request bursts do not exhaust direct connections.
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require"

# Legacy DB URL (optional)
# Keep this only when migrating old users from previous DB.
LEGACY_DATABASE_URL="postgresql://user:password@legacy-host/legacydb?sslmode=require"

# Google AI (Gemini)
GOOGLE_AI_API_KEY="your-gemini-api-key"

# Lemon Squeezy Payment (Optional)
LEMONSQUEEZY_API_KEY="your-lemonsqueezy-api-key"
LEMONSQUEEZY_STORE_ID="your-store-id"
LEMONSQUEEZY_PRODUCT_ID="your-product-id"
LEMONSQUEEZY_WEBHOOK_SECRET="your-webhook-secret"
NEXT_PUBLIC_VARIANT_PRO="your-variant-id"

# Notion Report Automation (Optional)
# Used by scripts/setup-notion-reports.cjs and scripts/upload-report-to-notion.cjs.
# This is separate from Notion MCP: automation needs a stable internal integration token for headless uploads.
NOTION_API_KEY="secret_your_notion_internal_integration_token"
# Parent page where the reports database will be created on first setup.
NOTION_REPORTS_PARENT_PAGE_ID="your-notion-parent-page-id"
# `make notion-setup` writes these back after creating/reusing the database.
NOTION_REPORTS_DATABASE_ID="your-notion-database-id"
NOTION_REPORTS_DATA_SOURCE_ID="your-notion-data-source-id"
NOTION_REPORTS_DATABASE_TITLE="Parrotkit Reports"
# Pin the API version used by the scripts so future API changes do not silently break automation.
NOTION_API_VERSION="2025-09-03"
# GitHub Actions/Vercel automation uses GitHub Secrets with the same names:
# - NOTION_API_KEY
# - NOTION_REPORTS_DATA_SOURCE_ID
